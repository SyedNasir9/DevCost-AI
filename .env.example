# DevCost AI Environment Configuration
# Copy this file to .env and update with your values

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
APP_ENV=development          # development, staging, production
DEMO_MODE=false               # true = use mock data, false = require AWS credentials
LOG_LEVEL=info               # debug, info, warn, error

# ===========================================
# DATABASE CONFIGURATION (Required)
# ===========================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=devcost_ai
DB_USER=devcost
DB_PASSWORD=devcost123
DB_SSLMODE=disable

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# SERVER CONFIGURATION
# ===========================================
SERVER_PORT=8080
GIN_MODE=release             # debug, release, test

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# ===========================================
# JWT CONFIGURATION
# ===========================================
JWT_SECRET=change-this-in-production
JWT_EXPIRE_HOURS=24

# ===========================================
# AWS CONFIGURATION (Required if DEMO_MODE=false)
# ===========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ===========================================
# SLACK CONFIGURATION (Optional)
# ===========================================
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_WEBHOOK_URL=

# ===========================================
# AI CONFIGURATION (Optional - Ollama)
# ===========================================
AI_ENABLED=false                           # Enable AI-powered analysis
AI_BASE_URL=http://localhost:11434         # Ollama server URL
AI_MODEL=llama3.2                          # Model to use
AI_TIMEOUT=30s                             # Request timeout

# ===========================================
# GCP CONFIGURATION (Optional)
# ===========================================
GCP_PROJECT_ID=
GCP_CREDENTIALS_FILE=

# ===========================================
# AZURE CONFIGURATION (Optional)
# ===========================================
AZURE_SUBSCRIPTION_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ===========================================
# EMAIL CONFIGURATION (Optional - for alerts)
# ===========================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ===========================================
# OPTIONAL: PGADMIN CONFIGURATION
# ===========================================
PGADMIN_EMAIL=admin@devcost-ai.com
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050
